# Copy this file to .env and adjust as needed.
# Only the OpenAI proxy URL is read from the Vite-injected env at build/runtime;
# server-side host/port are read by server/index.js when running the Node server.

# Frontend: OpenAI-compatible chat completions endpoint proxied by the Node server.
# In Docker this is set to /api/openai/chat/completions at build time (see Dockerfile).
# Note: The Gemini provider preset connects directly to Google's REST API; this proxy
# is only used for OpenAI-compatible providers (OpenAI, Qwen, custom).
VITE_OPENAI_PROXY_URL=/api/openai/chat/completions

# Node server (server/index.js) — only used when running `npm start` / Docker.
PORT=8080
HOST=0.0.0.0
